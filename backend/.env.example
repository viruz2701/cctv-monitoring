# CCTV Monitoring Platform — Environment Variables
# Скопируйте этот файл в .env и заполните реальными значениями

# === КРИТИЧЕСКИЕ (обязательные) ===
JWT_SECRET=change-me-to-a-random-64-char-string

# === База данных ===
# Подключение через отдельные параметры (используется в main.go)
DB_HOST=localhost
DB_USER=gb_user
DB_PASSWORD=gb_password
DB_NAME=gb_telemetry
# Альтернативно: DATABASE_URL (используется viper-ом в config.go)
# DATABASE_URL=postgres://gb_user:gb_password@localhost:5432/gb_telemetry?sslmode=disable

# === P2P Gateway ===
GB_P2P_GATEWAY_URL=http://localhost:8082
GB_P2P_API_KEY=change-me

# === CMMS Adapter ===
# internal (default) | atlas
GB_CMMS_ADAPTER=internal
GB_ATLAS_URL=
GB_ATLAS_API_KEY=

# === Telegram Bot ===
GB_TELEGRAM_ENABLED=false
GB_TELEGRAM_TOKEN=

# === Encryption Keys ===
# AES-256 ключ для шифрования push-токенов (64 hex символа = 32 байта)
PUSH_TOKEN_ENCRYPTION_KEY=

# === Audit HMAC Key (ISO 27001 A.12.4, СТБ 34.101.30) ===
# Минимум 32 байта (256 бит) для HMAC-подписи audit_log
# Переменная: GB_AUDIT_HMAC_KEY
GB_AUDIT_HMAC_KEY=change-me-to-a-random-string-at-least-32-bytes

# === DeepSeek AI (Gatekeeper) ===
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1