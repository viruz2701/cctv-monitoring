# CCTV Monitoring Platform — Environment Variables
# Скопируйте в .env и заполните реальными значениями

# ═══════════════════════════════════════════════════════════════════════
# КРИТИЧЕСКИЕ (обязательные)
# ═══════════════════════════════════════════════════════════════════════
JWT_SECRET=change-me-to-a-random-64-char-string
GB_AUDIT_HMAC_KEY=change-me-to-a-random-string-at-least-32-bytes

# ═══════════════════════════════════════════════════════════════════════
# База данных
# ═══════════════════════════════════════════════════════════════════════
# Подключение через отдельные параметры
DB_HOST=localhost
DB_PORT=5432
DB_USER=gb_user
# ⚠ В production ДОЛЖЕН быть установлен через env (не используется default)
DB_PASSWORD=
DB_NAME=gb_telemetry
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=5m
DB_MAX_CONN_IDLE_TIME=3m

# ═══════════════════════════════════════════════════════════════════════
# NATS Event Bus (требуется для production, КИИ РБ)
# ═══════════════════════════════════════════════════════════════════════
NATS_URL=nats://localhost:4222
NATS_REQUIRED=true
NATS_TLS=false
USE_NATS_KV=true

# ═══════════════════════════════════════════════════════════════════════
# P2P Gateway
# ═══════════════════════════════════════════════════════════════════════
GB_P2P_GATEWAY_URL=http://localhost:8082
GB_P2P_API_KEY=change-me

# ═══════════════════════════════════════════════════════════════════════
# CMMS Adapter
# ═══════════════════════════════════════════════════════════════════════
GB_CMMS_ADAPTER=internal

# Atlas CMMS
GB_ATLAS_URL=
GB_ATLAS_API_KEY=
GB_ATLAS_CLIENT_ID=
GB_ATLAS_CLIENT_SECRET=

# ServiceNow
GB_SERVICENOW_INSTANCE_URL=
GB_SERVICENOW_CLIENT_ID=
GB_SERVICENOW_CLIENT_SECRET=
GB_SERVICENOW_USERNAME=
GB_SERVICENOW_PASSWORD=

# 1С:ТОИР
GB_TOIR_BASE_URL=
GB_TOIR_USERNAME=
GB_TOIR_PASSWORD=

# Jira
GB_JIRA_BASE_URL=
GB_JIRA_EMAIL=
GB_JIRA_API_TOKEN=

# Bi-directional ITSM Sync
GB_ITSMSYNCINTERVAL=5m

# ═══════════════════════════════════════════════════════════════════════
# Telegram Bot
# ═══════════════════════════════════════════════════════════════════════
GB_TELEGRAM_ENABLED=false
GB_TELEGRAM_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# Encryption & Crypto (СТБ 34.101.30)
# ═══════════════════════════════════════════════════════════════════════
PUSH_TOKEN_ENCRYPTION_KEY=
GB_CRYPTO_PROVIDER=aes   # aes | belt | gost | sm

# ═══════════════════════════════════════════════════════════════════════
# DeepSeek AI (Gatekeeper)
# ═══════════════════════════════════════════════════════════════════════
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# ═══════════════════════════════════════════════════════════════════════
# CORS (OWASP ASVS L3 V9.1)
# ═══════════════════════════════════════════════════════════════════════
# Через запятую: https://app.example.com,https://admin.example.com
GB_CORS_ALLOWED_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════
# Администратор (первый запуск)
# ═══════════════════════════════════════════════════════════════════════
GB_ADMIN_PASSWORD=
