# CCTV Health Monitor — Frontend Environment Variables
# Скопируйте в .env и заполните реальными значениями

# === API (обязательные) ===
# URL API-сервера (backend)
VITE_API_URL=/api/v1

# URL WebSocket для real-time уведомлений
# По умолчанию выводится из VITE_API_URL или window.location
VITE_WS_URL=

# === Sentry (опционально) ===
# DSN для отправки ошибок в Sentry
VITE_SENTRY_DSN=
# Включить Sentry в dev-режиме (true/false)
VITE_SENTRY_DEV=false
