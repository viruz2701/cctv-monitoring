{
  "name": "cctv-health-monitor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate:api": "openapi-typescript ../backend/docs/openapi.yaml --output src/types/api.ts",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ci": "playwright test --project=chromium --reporter=list,github",
    "test:a11y": "playwright test --project=a11y",
    "test:a11y:ci": "playwright test --project=a11y --forbid-only --reporter=list,github",
    "test:visual": "playwright test --project=visual",
    "test:all": "playwright test --project=chromium --project=a11y",
    "test:all:ci": "playwright test --project=chromium --project=a11y --forbid-only --reporter=list,github",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --reporter=verbose"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/resource": "^6.1.21",
    "@fullcalendar/resource-timeline": "^6.1.21",
    "@fullcalendar/timeline": "^6.1.21",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^4.1.3",
    "@sentry/react": "^9.12.0",
    "@sentry/vite-plugin": "^3.3.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-grid-layout": "^1.3.6",
    "@xyflow/react": "^12.11.1",
    "axios": "^1.17.0",
    "date-fns": "^4.1.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.563.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-compare-image": "^3.5.17",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^15.0.0",
    "react-grid-layout": "^2.2.3",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "react-joyride": "^3.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.9.0",
    "remark-gfm": "^4.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.18"
  }
}
